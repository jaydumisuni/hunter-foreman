# Public demo environment template
APP_NAME=Hunter Foreman
APP_ENV=demo
PORT=3000

# AI classifier provider.
# mock/rules keeps the public demo fully local with deterministic fallback routing.
# fireworks enables provider-backed classification through the OpenAI-compatible Fireworks API.
AI_PROVIDER=mock
AI_API_KEY=
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b

WHATSAPP_PROVIDER=mock
EMAIL_PROVIDER=mock

# Optional external app bridge.
# When set, Hunter Foreman will POST created tasks to:
#   $FOREMAN_APP_WEBHOOK_URL/foreman/tasks
FOREMAN_APP_WEBHOOK_URL=
FOREMAN_APP_TOKEN=
